        "--font-mono": "\"Courier New\", \"Lucida Console\", monospace",
        "--win98-face": "#4e4e4e",
        "--win98-window": "#5a5a5a",
        "--win98-light": "#9f9f9f",
        "--win98-mid": "#2f2f2f",
        "--win98-dark": "#151515",
        "--win98-black": "#060606",
        "--win98-accent": "#2e5fff",
        "--background": "#3a3a3a",
        "--foreground": "#f2f2f2",
        "--card": "#3a3a3a",
