        "background": "var(--win98-face)",
        "border": "none",
        "box-shadow": "inset -1px -1px var(--win98-black), inset 1px 1px var(--win98-light), inset -2px -2px var(--win98-mid), inset 2px 2px var(--win98-window)",
        "border-radius": "0",
        "text-shadow": "0 0 var(--foreground)"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"button\"], [data-slot=\"tabs-trigger\"], [data-slot=\"toggle\"], [data-slot=\"toggle-group-item\"], [data-slot=\"carousel-next\"], [data-slot=\"carousel-previous\"], [data-slot=\"pagination-link\"], [data-slot=\"sidebar-trigger\"], [data-slot=\"menubar-trigger\"], [data-slot=\"navigation-menu-trigger\"], [data-slot=\"accordion-trigger\"]):is(:active, [data-state=\"open\"], [data-state=\"on\"], [data-state=\"checked\"])": {
        "box-shadow": "inset -1px -1px var(--win98-light), inset 1px 1px var(--win98-black), inset -2px -2px var(--win98-window), inset 2px 2px var(--win98-mid)",
        "text-shadow": "1px 1px var(--foreground)"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"input\"], [data-slot=\"textarea\"], [data-slot=\"select-trigger\"], [data-slot=\"command-input-wrapper\"], [data-slot=\"input-group-control\"], [data-slot=\"input-otp-slot\"], [data-slot=\"checkbox\"], [data-slot=\"radio-group-item\"], [data-slot=\"switch\"], [data-slot=\"slider-track\"], [data-slot=\"progress\"], [data-slot=\"scroll-area-viewport\"])": {
        "background": "var(--input)",
        "border": "none",
        "box-shadow": "inset -1px -1px var(--win98-light), inset 1px 1px var(--win98-mid), inset -2px -2px var(--win98-window), inset 2px 2px var(--win98-black)",
        "border-radius": "0"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"switch-thumb\"], [data-slot=\"slider-thumb\"], [data-slot=\"radio-group-indicator\"], [data-slot=\"checkbox-indicator\"])": {
        "background": "var(--win98-face)",
        "border": "none",
        "box-shadow": "inset -1px -1px var(--win98-black), inset 1px 1px var(--win98-light), inset -2px -2px var(--win98-mid), inset 2px 2px var(--win98-window)",
        "border-radius": "0"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"tabs-list\"], [data-slot=\"sidebar\"], [data-slot=\"sidebar-container\"], [data-slot=\"sidebar-inset\"], [data-slot=\"menubar\"], [data-slot=\"input-group-addon\"])": {
        "background": "var(--win98-face)",
        "border": "2px solid var(--win98-mid)",
        "border-top-color": "var(--win98-light)",
        "border-left-color": "var(--win98-light)",
        "border-right-color": "var(--win98-dark)",
        "border-bottom-color": "var(--win98-dark)",
        "box-shadow": "inset 1px 1px var(--win98-window), inset -1px -1px var(--win98-mid)",
        "border-radius": "0"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"badge\"], [data-slot=\"kbd\"], [data-slot=\"pagination-link\"], [data-slot=\"breadcrumb-link\"])": {
        "background": "var(--win98-face)",
        "border": "1px solid var(--win98-dark)",
        "border-radius": "0"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"command-item\"], [data-slot=\"select-item\"], [data-slot=\"dropdown-menu-item\"], [data-slot=\"dropdown-menu-checkbox-item\"], [data-slot=\"dropdown-menu-radio-item\"], [data-slot=\"dropdown-menu-sub-trigger\"], [data-slot=\"context-menu-item\"], [data-slot=\"context-menu-checkbox-item\"], [data-slot=\"context-menu-radio-item\"], [data-slot=\"context-menu-sub-trigger\"], [data-slot=\"menubar-item\"], [data-slot=\"menubar-checkbox-item\"], [data-slot=\"menubar-radio-item\"], [data-slot=\"menubar-sub-trigger\"], [data-slot=\"navigation-menu-link\"])": {
        "border-radius": "0"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"command-item\"], [data-slot=\"select-item\"], [data-slot=\"dropdown-menu-item\"], [data-slot=\"dropdown-menu-checkbox-item\"], [data-slot=\"dropdown-menu-radio-item\"], [data-slot=\"dropdown-menu-sub-trigger\"], [data-slot=\"context-menu-item\"], [data-slot=\"context-menu-checkbox-item\"], [data-slot=\"context-menu-radio-item\"], [data-slot=\"context-menu-sub-trigger\"], [data-slot=\"menubar-item\"], [data-slot=\"menubar-checkbox-item\"], [data-slot=\"menubar-radio-item\"], [data-slot=\"menubar-sub-trigger\"], [data-slot=\"navigation-menu-link\"]):is([data-highlighted], [data-selected=\"true\"], [aria-selected=\"true\"], [data-state=\"open\"], [data-active], [aria-current=\"page\"])": {
        "background": "var(--win98-accent)",
        "color": "#ffffff"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"command-item\"], [data-slot=\"select-item\"], [data-slot=\"dropdown-menu-item\"], [data-slot=\"dropdown-menu-checkbox-item\"], [data-slot=\"dropdown-menu-radio-item\"], [data-slot=\"dropdown-menu-sub-trigger\"], [data-slot=\"context-menu-item\"], [data-slot=\"context-menu-checkbox-item\"], [data-slot=\"context-menu-radio-item\"], [data-slot=\"context-menu-sub-trigger\"], [data-slot=\"menubar-item\"], [data-slot=\"menubar-checkbox-item\"], [data-slot=\"menubar-radio-item\"], [data-slot=\"menubar-sub-trigger\"], [data-slot=\"navigation-menu-link\"]):is([data-highlighted], [data-selected=\"true\"], [aria-selected=\"true\"], [data-state=\"open\"], [data-active], [aria-current=\"page\"]) :is(svg)": {
        "color": "#ffffff"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"separator\"], [data-slot=\"dropdown-menu-separator\"], [data-slot=\"context-menu-separator\"], [data-slot=\"menubar-separator\"], [data-slot=\"select-separator\"], [data-slot=\"command-separator\"], [data-slot=\"item-separator\"], [data-slot=\"field-separator\"])": {
        "border": "0",
        "height": "2px",
        "background": "linear-gradient(to bottom, var(--win98-mid) 0 1px, var(--win98-light) 1px 2px)"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"button\"], [data-slot=\"tabs-trigger\"], [data-slot=\"toggle\"], [data-slot=\"toggle-group-item\"], [data-slot=\"carousel-next\"], [data-slot=\"carousel-previous\"], [data-slot=\"pagination-link\"], [data-slot=\"sidebar-trigger\"], [data-slot=\"menubar-trigger\"], [data-slot=\"navigation-menu-trigger\"], [data-slot=\"accordion-trigger\"], [data-slot=\"input\"], [data-slot=\"textarea\"], [data-slot=\"select-trigger\"], [data-slot=\"input-group-control\"], [data-slot=\"checkbox\"], [data-slot=\"radio-group-item\"], [data-slot=\"switch\"]):focus-visible": {
        "outline": "1px dotted var(--foreground)",
        "outline-offset": "-4px"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"button\"], [data-slot=\"tabs-trigger\"], [data-slot=\"toggle\"], [data-slot=\"toggle-group-item\"], [data-slot=\"carousel-next\"], [data-slot=\"carousel-previous\"], [data-slot=\"pagination-link\"], [data-slot=\"sidebar-trigger\"], [data-slot=\"menubar-trigger\"], [data-slot=\"navigation-menu-trigger\"], [data-slot=\"accordion-trigger\"], [data-slot=\"input\"], [data-slot=\"textarea\"], [data-slot=\"select-trigger\"], [data-slot=\"input-group-control\"]):disabled": {
        "color": "var(--win98-mid)",
        "text-shadow": "1px 1px 0 var(--win98-light)"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"input\"]:disabled, [data-slot=\"input\"][readonly], [data-slot=\"textarea\"]:disabled, [data-slot=\"select-trigger\"]:disabled)": {
        "background": "var(--win98-face)"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"sheet-title\"], [data-slot=\"alert-dialog-title\"], [data-slot=\"drawer-title\"], [data-slot=\"popover-title\"])": {
        "background": "linear-gradient(90deg, var(--win98-accent) 0%, color-mix(in srgb, var(--win98-accent) 75%, black) 100%)",
        "color": "#ffffff",
        "padding": "0.125rem 0.375rem",
        "font-weight": "700"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"card-header\"], [data-slot=\"sheet-header\"], [data-slot=\"drawer-header\"], [data-slot=\"popover-header\"])": {
        "background": "linear-gradient(90deg, var(--win98-accent) 0%, color-mix(in srgb, var(--win98-accent) 75%, black) 100%)",
        "color": "#ffffff",
        "padding-top": "3px",
        "padding-bottom": "3px"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-content\"]": {
        "padding": "8px",
        "gap": "10px"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-header\"]": {
        "gap": "6px"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-title\"]": {
        "background": "linear-gradient(90deg, var(--win98-accent) 0%, color-mix(in srgb, var(--win98-accent) 75%, black) 100%)",
        "color": "#ffffff",
        "padding": "3px 24px 3px 6px",
        "margin": "-8px -8px 4px -8px",
        "font-size": "11px",
        "line-height": "1.2",
        "font-weight": "700"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-description\"]": {
        "color": "var(--foreground)",
        "padding-left": "2px",
        "padding-right": "2px"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-close\"]": {
        "top": "3px",
        "right": "3px",
        "opacity": "1",
        "width": "16px",
        "height": "14px",
        "padding": "0",
        "background": "var(--win98-face)",
        "border": "none",
        "border-radius": "0",
        "display": "inline-flex",
        "align-items": "center",
        "justify-content": "center",
        "box-shadow": "inset -1px -1px var(--win98-black), inset 1px 1px var(--win98-light), inset -2px -2px var(--win98-mid), inset 2px 2px var(--win98-window)"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-close\"]:is(:hover, :focus-visible)": {
        "opacity": "1",
        "outline": "1px dotted var(--foreground)",
        "outline-offset": "-2px"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-close\"]:active": {
        "box-shadow": "inset -1px -1px var(--win98-light), inset 1px 1px var(--win98-black), inset -2px -2px var(--win98-window), inset 2px 2px var(--win98-mid)"
      },
      "[data-theme^=\"corti-win98\"] [data-slot=\"dialog-close\"] :is(svg)": {
        "width": "10px",
        "height": "10px",
        "color": "var(--foreground)"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"table-head\"])": {
        "box-shadow": "inset -1px -1px var(--win98-black), inset 1px 1px var(--win98-light), inset -2px -2px var(--win98-mid), inset 2px 2px var(--win98-window)",
        "background": "var(--win98-face)",
        "font-weight": "400"
      },
      "[data-theme^=\"corti-win98\"] ::-webkit-scrollbar": {
        "width": "16px",
        "height": "16px"
      },
      "[data-theme^=\"corti-win98\"] ::-webkit-scrollbar-thumb": {
        "background": "var(--win98-window)",
        "border": "none",
        "box-shadow": "inset -1px -1px var(--win98-black), inset 1px 1px var(--win98-light), inset -2px -2px var(--win98-mid), inset 2px 2px var(--win98-window)"
      },
      "[data-theme^=\"corti-win98\"] ::-webkit-scrollbar-track": {
        "background": "var(--win98-face)"
      },
      "[data-theme^=\"corti-win98\"] ::selection": {
        "background": "var(--win98-accent)",
        "color": "#ffffff"
      }
    }
  },
  "type": "registry:theme"
}
