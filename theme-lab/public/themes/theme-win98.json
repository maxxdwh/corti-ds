{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme-win98",
  "title": "Corti Win98 Theme",
  "description": "Classic Windows 98 style theme with beveled controls and classic desktop chrome.",
  "registryDependencies": [
    "@corti/theme-core"
  ],
  "css": {
