        "--win98-mid": "#808080",
        "--win98-dark": "#404040",
        "--win98-black": "#0a0a0a",
        "--win98-accent": "#000080",
        "--background": "#c0c0c0",
        "--foreground": "#000000",
        "--card": "#c0c0c0",
        "--card-foreground": "#000000",
        "--popover": "#c0c0c0",
        "--popover-foreground": "#000000",
        "--primary": "#000080",
        "--primary-foreground": "#ffffff",
        "--secondary": "#c0c0c0",
        "--secondary-foreground": "#000000",
        "--muted": "#dfdfdf",
        "--muted-foreground": "#303030",
