        "--primary": "#2e5fff",
        "--primary-foreground": "#ffffff",
        "--secondary": "#555555",
        "--secondary-foreground": "#f2f2f2",
        "--muted": "#4b4b4b",
        "--muted-foreground": "#d8d8d8",
        "--accent": "#2e5fff",
        "--accent-foreground": "#ffffff",
        "--destructive": "#cc4f4f",
        "--destructive-foreground": "#ffffff",
        "--border": "#8f8f8f",
        "--input": "#242424",
        "--ring": "#7ca0ff",
        "--radius": "0px",
        "--radius-sm": "0px",
        "--radius-md": "0px",
        "--radius-lg": "0px",
        "--radius-xl": "0px",
        "--radius-2xl": "0px",
        "--radius-3xl": "0px",
        "--radius-4xl": "0px",
        "--chart-1": "#7ca0ff",
        "--chart-2": "#d98eff",
        "--chart-3": "#82d682",
        "--chart-4": "#e0c176",
        "--chart-5": "#df9090",
        "--sidebar": "#3a3a3a",
        "--sidebar-foreground": "#f2f2f2",
        "--sidebar-primary": "#2e5fff",
        "--sidebar-primary-foreground": "#ffffff",
        "--sidebar-accent": "#4b4b4b",
        "--sidebar-accent-foreground": "#f2f2f2",
        "--sidebar-border": "#8f8f8f",
        "--sidebar-ring": "#7ca0ff",
        "--variant-error-bg": "#5a2b2b",
        "--variant-error-border": "#b76464",
        "--variant-error-text": "#ffd6d6",
        "--variant-info-bg": "#1f2e5b",
        "--variant-info-border": "#5f78d8",
        "--variant-info-text": "#d4e0ff",
        "--variant-success-bg": "#234723",
        "--variant-success-border": "#5faa5f",
        "--variant-success-text": "#d6f4d6",
        "--variant-warning-bg": "#5a4920",
        "--variant-warning-border": "#d2aa57",
        "--variant-warning-text": "#ffe7bd"
      },
      "[data-theme^=\"corti-win98\"]": {
        "font-family": "\"MS Sans Serif\", \"Tahoma\", \"Segoe UI\", sans-serif",
        "font-size": "11px",
        "line-height": "1.2",
        "background": "var(--background)",
        "font-smooth": "never",
        "-webkit-font-smoothing": "none"
      },
      "[data-theme^=\"corti-win98\"] :is(h1, h2, h3, h4, h5, h6)": {
        "font-weight": "700",
        "letter-spacing": "0"
      },
      "[data-theme^=\"corti-win98\"] :is([data-slot=\"card\"], [data-slot=\"dialog-content\"], [data-slot=\"alert-dialog-content\"], [data-slot=\"popover-content\"], [data-slot=\"sheet-content\"], [data-slot=\"drawer-content\"], [data-slot=\"dropdown-menu-content\"], [data-slot=\"dropdown-menu-sub-content\"], [data-slot=\"context-menu-content\"], [data-slot=\"context-menu-sub-content\"], [data-slot=\"menubar-content\"], [data-slot=\"menubar-sub-content\"], [data-slot=\"navigation-menu-content\"], [data-slot=\"navigation-menu-viewport\"], [data-slot=\"hover-card-content\"], [data-slot=\"tooltip-content\"], [data-slot=\"select-content\"], [data-slot=\"command\"], [data-slot=\"empty\"], [data-slot=\"table-container\"])": {
