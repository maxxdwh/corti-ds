        "button-px": "1rem",
        "button-py": "0.5rem",
        "input-height": "2.25rem",
        "input-px": "0.75rem",
        "input-py": "0.25rem",
        "textarea-min-height": "4rem",
        "textarea-px": "0.75rem",
        "textarea-py": "0.5rem",
        "select-height": "2.25rem",
        "select-px": "0.75rem",
        "select-py": "0.5rem",
        "switch-height": "1.15rem",
        "switch-width": "2rem",
        "button-radius": "var(--radius)",
        "input-radius": "var(--radius)",
        "textarea-radius": "var(--radius)",
        "select-radius": "var(--radius)",
