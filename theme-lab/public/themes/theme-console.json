        "--sidebar": "hsl(0 0% 98%)",
        "--sidebar-border": "hsl(0 0% 89.8%)",
        "--sidebar-foreground": "hsl(0 0% 9%)",
        "--sidebar-primary": "hsl(0 0% 9%)",
        "--sidebar-primary-foreground": "hsl(0 0% 98%)",
        "--sidebar-ring": "hsl(0 0% 3.9%)",
        "--variant-error-bg": "hsl(0 100% 97%)",
        "--variant-error-border": "hsl(0 93% 86%)",
        "--variant-error-text": "hsl(0 72% 37%)",
        "--variant-info-bg": "hsl(210 100% 97%)",
