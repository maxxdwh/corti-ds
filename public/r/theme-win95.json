{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme-win95",
  "title": "Corti Win95 Theme",
  "description": "Classic Windows 95 style theme with beveled controls, system fonts, and iconic teal desktop tones.",
  "registryDependencies": [
    "@corti/theme-core"
  ],
  "css": {
    "@layer base": {
      "html[data-theme=\"corti-win95-light\"]": {
        "--font-sans": "\"MS Sans Serif\", \"Tahoma\", \"Segoe UI\", sans-serif",
        "--font-mono": "\"Courier New\", \"Lucida Console\", monospace",
        "--background": "#008080",
        "--foreground": "#000000",
        "--card": "#c0c0c0",
        "--card-foreground": "#000000",
        "--popover": "#c0c0c0",
        "--popover-foreground": "#000000",
        "--primary": "#000080",
        "--primary-foreground": "#ffffff",
        "--secondary": "#c0c0c0",
        "--secondary-foreground": "#000000",
        "--muted": "#dfdfdf",
        "--muted-foreground": "#303030",
        "--accent": "#000080",
        "--accent-foreground": "#ffffff",
        "--destructive": "#a80000",
        "--destructive-foreground": "#ffffff",
        "--border": "#808080",
        "--input": "#ffffff",
        "--ring": "#000080",
        "--radius": "0px",
        "--radius-sm": "0px",
        "--radius-md": "0px",
        "--radius-lg": "0px",
        "--radius-xl": "0px",
        "--radius-2xl": "0px",
        "--radius-3xl": "0px",
        "--radius-4xl": "0px",
        "--chart-1": "#000080",
        "--chart-2": "#800080",
        "--chart-3": "#008000",
        "--chart-4": "#808000",
        "--chart-5": "#800000",
        "--sidebar": "#c0c0c0",
        "--sidebar-foreground": "#000000",
        "--sidebar-primary": "#000080",
        "--sidebar-primary-foreground": "#ffffff",
        "--sidebar-accent": "#dfdfdf",
        "--sidebar-accent-foreground": "#000000",
        "--sidebar-border": "#808080",
        "--sidebar-ring": "#000080",
        "--variant-error-bg": "#ffe8e8",
        "--variant-error-border": "#c06060",
        "--variant-error-text": "#7a0000",
        "--variant-info-bg": "#e8efff",
        "--variant-info-border": "#6a7fcf",
        "--variant-info-text": "#102a78",
        "--variant-success-bg": "#e8f6e8",
        "--variant-success-border": "#669966",
        "--variant-success-text": "#134d13",
        "--variant-warning-bg": "#fff5de",
        "--variant-warning-border": "#bc9450",
        "--variant-warning-text": "#5f3f11"
      },
      "html[data-theme=\"corti-win95-dark\"]": {
        "--font-sans": "\"MS Sans Serif\", \"Tahoma\", \"Segoe UI\", sans-serif",
        "--font-mono": "\"Courier New\", \"Lucida Console\", monospace",
        "--background": "#003a3a",
        "--foreground": "#f2f2f2",
        "--card": "#3a3a3a",
        "--card-foreground": "#f2f2f2",
        "--popover": "#3a3a3a",
        "--popover-foreground": "#f2f2f2",
        "--primary": "#2e5fff",
        "--primary-foreground": "#ffffff",
        "--secondary": "#555555",
        "--secondary-foreground": "#f2f2f2",
        "--muted": "#4b4b4b",
        "--muted-foreground": "#d8d8d8",
        "--accent": "#2e5fff",
        "--accent-foreground": "#ffffff",
        "--destructive": "#cc4f4f",
        "--destructive-foreground": "#ffffff",
        "--border": "#8f8f8f",
        "--input": "#242424",
        "--ring": "#7ca0ff",
        "--radius": "0px",
        "--radius-sm": "0px",
        "--radius-md": "0px",
        "--radius-lg": "0px",
        "--radius-xl": "0px",
        "--radius-2xl": "0px",
        "--radius-3xl": "0px",
        "--radius-4xl": "0px",
        "--chart-1": "#7ca0ff",
        "--chart-2": "#d98eff",
        "--chart-3": "#82d682",
        "--chart-4": "#e0c176",
        "--chart-5": "#df9090",
        "--sidebar": "#3a3a3a",
        "--sidebar-foreground": "#f2f2f2",
        "--sidebar-primary": "#2e5fff",
        "--sidebar-primary-foreground": "#ffffff",
        "--sidebar-accent": "#4b4b4b",
        "--sidebar-accent-foreground": "#f2f2f2",
        "--sidebar-border": "#8f8f8f",
        "--sidebar-ring": "#7ca0ff",
        "--variant-error-bg": "#5a2b2b",
        "--variant-error-border": "#b76464",
        "--variant-error-text": "#ffd6d6",
        "--variant-info-bg": "#1f2e5b",
        "--variant-info-border": "#5f78d8",
        "--variant-info-text": "#d4e0ff",
        "--variant-success-bg": "#234723",
        "--variant-success-border": "#5faa5f",
        "--variant-success-text": "#d6f4d6",
        "--variant-warning-bg": "#5a4920",
        "--variant-warning-border": "#d2aa57",
        "--variant-warning-text": "#ffe7bd"
      },
      "html[data-theme^=\"corti-win95\"]": {
        "font-family": "\"MS Sans Serif\", \"Tahoma\", \"Segoe UI\", sans-serif",
        "font-size": "13px",
        "line-height": "1.2"
      },
      "html[data-theme^=\"corti-win95\"] :is(h1, h2, h3, h4, h5, h6)": {
        "font-weight": "700",
        "letter-spacing": "0"
      },
      "html[data-theme^=\"corti-win95\"] :is([data-slot=\"button\"], button, [role=\"button\"], [data-slot=\"card\"], [data-slot=\"dialog-content\"], [data-slot=\"popover-content\"], [data-slot=\"sheet-content\"], [data-slot=\"dropdown-menu-content\"], [data-slot=\"context-menu-content\"])": {
        "border": "2px solid #808080",
        "border-top-color": "#ffffff",
        "border-left-color": "#ffffff",
        "border-right-color": "#404040",
        "border-bottom-color": "#404040",
        "box-shadow": "inset 1px 1px #dfdfdf, inset -1px -1px #808080"
      },
      "html[data-theme^=\"corti-win95\"] :is([data-slot=\"button\"], button, [role=\"button\"]):active": {
        "border-top-color": "#404040",
        "border-left-color": "#404040",
        "border-right-color": "#ffffff",
        "border-bottom-color": "#ffffff",
        "box-shadow": "inset 1px 1px #808080, inset -1px -1px #dfdfdf"
      },
      "html[data-theme^=\"corti-win95\"] :is(input, textarea, select, [data-slot=\"input\"], [data-slot=\"textarea\"], [data-slot=\"select-trigger\"])": {
        "background": "#ffffff",
        "border": "2px solid #808080",
        "border-top-color": "#404040",
        "border-left-color": "#404040",
        "border-right-color": "#ffffff",
        "border-bottom-color": "#ffffff",
        "box-shadow": "inset 1px 1px #808080, inset -1px -1px #dfdfdf"
      },
      "html[data-theme^=\"corti-win95\"] ::-webkit-scrollbar": {
        "width": "16px",
        "height": "16px"
      },
      "html[data-theme^=\"corti-win95\"] ::-webkit-scrollbar-thumb": {
        "background": "#c0c0c0",
        "border": "2px solid #808080",
        "border-top-color": "#ffffff",
        "border-left-color": "#ffffff",
        "border-right-color": "#404040",
        "border-bottom-color": "#404040"
      },
      "html[data-theme^=\"corti-win95\"] ::selection": {
        "background": "#000080",
        "color": "#ffffff"
      }
    }
  },
  "type": "registry:theme"
}