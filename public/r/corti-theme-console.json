{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "corti-theme-console",
  "title": "Corti Console Theme",
  "description": "Monochrome console-inspired light and dark themes.",
  "registryDependencies": [
    "@corti/corti-theme-core"
  ],
  "css": {
    "@layer base": {
      "html[data-theme=\"corti-console-light\"]": {
        "--font-sans": "\"Booton\", ui-sans-serif, system-ui, sans-serif",
        "--background": "hsl(0 0% 100%)",
        "--foreground": "hsl(0 0% 6%)",
        "--card": "hsl(0 0% 100%)",
        "--card-foreground": "hsl(0 0% 6%)",
        "--popover": "hsl(0 0% 100%)",
        "--popover-foreground": "hsl(0 0% 6%)",
        "--primary": "hsl(0 0% 6%)",
        "--primary-foreground": "hsl(0 0% 100%)",
        "--secondary": "hsl(0 0% 100%)",
        "--secondary-foreground": "hsl(0 0% 6%)",
        "--muted": "hsl(0 0% 98%)",
        "--muted-foreground": "hsl(0 0% 41%)",
        "--accent": "hsl(0 0% 98%)",
        "--accent-foreground": "hsl(222 47% 11%)",
        "--destructive": "hsl(0 84% 60%)",
        "--destructive-foreground": "hsl(0 0% 100%)",
        "--border": "hsl(0 0% 93%)",
        "--input": "hsl(0 0% 90%)",
        "--ring": "hsl(215 16% 47%)",
        "--radius": "0.5rem",
        "--sidebar-accent": "hsl(0 0% 94%)",
        "--sidebar-accent-foreground": "hsl(0 0% 1%)",
        "--sidebar": "hsl(0 0% 98%)",
        "--sidebar-border": "hsl(0 0% 78%)",
        "--sidebar-foreground": "hsl(240 5% 37%)",
        "--sidebar-primary": "hsl(0 0% 1%)",
        "--sidebar-primary-foreground": "hsl(0 0% 95%)",
        "--sidebar-ring": "hsl(0 0% 35%)",
        "--variant-error-bg": "hsl(0 100% 97%)",
        "--variant-error-border": "hsl(0 93% 86%)",
        "--variant-error-text": "hsl(0 72% 37%)",
        "--variant-info-bg": "hsl(210 100% 97%)",
        "--variant-info-border": "hsl(210 100% 88%)",
        "--variant-info-text": "hsl(215 60% 23%)",
        "--variant-success-bg": "hsl(142 76% 97%)",
        "--variant-success-border": "hsl(142 61% 86%)",
        "--variant-success-text": "hsl(142 70% 28%)",
        "--variant-warning-bg": "hsl(38 100% 96%)",
        "--variant-warning-border": "hsl(38 94% 84%)",
        "--variant-warning-text": "hsl(30 92% 34%)"
      },
      "html[data-theme=\"corti-console-dark\"]": {
        "--font-sans": "\"Booton\", ui-sans-serif, system-ui, sans-serif",
        "--background": "hsl(0 0% 6%)",
        "--foreground": "hsl(0 0% 90%)",
        "--card": "hsl(0 0% 10%)",
        "--card-foreground": "hsl(0 0% 90%)",
        "--popover": "hsl(0 0% 10%)",
        "--popover-foreground": "hsl(0 0% 90%)",
        "--primary": "hsl(0 0% 100%)",
        "--primary-foreground": "hsl(0 0% 6%)",
        "--secondary": "hsl(0 0% 16%)",
        "--secondary-foreground": "hsl(0 0% 90%)",
        "--muted": "hsl(0 0% 16%)",
        "--muted-foreground": "hsl(0 0% 65%)",
        "--accent": "hsl(0 0% 16%)",
        "--accent-foreground": "hsl(0 0% 90%)",
        "--destructive": "hsl(0 63% 31%)",
        "--destructive-foreground": "hsl(0 0% 100%)",
        "--border": "hsl(0 0% 25%)",
        "--input": "hsl(0 0% 25%)",
        "--ring": "hsl(0 0% 80%)",
        "--radius": "0.5rem",
        "--sidebar-accent": "hsl(0 0% 16%)",
        "--sidebar-accent-foreground": "hsl(0 0% 90%)",
        "--sidebar": "hsl(0 0% 12%)",
        "--sidebar-border": "hsl(0 0% 25%)",
        "--sidebar-foreground": "hsl(0 0% 90%)",
        "--sidebar-primary": "hsl(0 0% 100%)",
        "--sidebar-primary-foreground": "hsl(0 0% 6%)",
        "--sidebar-ring": "hsl(0 0% 100%)",
        "--variant-error-bg": "hsl(0 60% 9%)",
        "--variant-error-border": "hsl(0 52% 28%)",
        "--variant-error-text": "hsl(0 68% 82%)",
        "--variant-info-bg": "hsl(222 67% 10%)",
        "--variant-info-border": "hsl(222 51% 28%)",
        "--variant-info-text": "hsl(210 20% 85%)",
        "--variant-success-bg": "hsl(150 40% 8%)",
        "--variant-success-border": "hsl(150 35% 28%)",
        "--variant-success-text": "hsl(140 36% 80%)",
        "--variant-warning-bg": "hsl(60 100% 6%)",
        "--variant-warning-border": "hsl(60 100% 18%)",
        "--variant-warning-text": "hsl(48 96% 78%)"
      }
    }
  },
  "type": "registry:theme"
}