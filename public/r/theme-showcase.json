{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme-showcase",
  "title": "Corti Showcase Theme",
  "description": "Playful 90s 8-bit inspired showcase themes using IBM Plex Mono typography and square edges.",
  "registryDependencies": [
    "@corti/theme-core"
  ],
  "css": {
    "@layer base": {
      "html[data-theme=\"corti-showcase-light\"]": {
        "--font-sans": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "--font-mono": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "--background": "hsl(73 100% 97%)",
        "--foreground": "hsl(229 35% 14%)",
        "--card": "hsl(73 60% 94%)",
        "--card-foreground": "hsl(229 35% 14%)",
        "--popover": "hsl(73 60% 94%)",
        "--popover-foreground": "hsl(229 35% 14%)",
        "--primary": "hsl(250 78% 55%)",
        "--primary-foreground": "hsl(0 0% 100%)",
        "--secondary": "hsl(216 90% 90%)",
        "--secondary-foreground": "hsl(229 35% 14%)",
        "--muted": "hsl(216 60% 92%)",
        "--muted-foreground": "hsl(229 20% 36%)",
        "--accent": "#B8F818",
        "--accent-foreground": "hsl(229 35% 10%)",
        "--destructive": "hsl(0 84% 58%)",
        "--destructive-foreground": "hsl(0 0% 100%)",
        "--border": "hsl(229 35% 28%)",
        "--input": "hsl(229 35% 34%)",
        "--ring": "#B8F818",
        "--radius": "0px",
        "--radius-sm": "0px",
        "--radius-md": "0px",
        "--radius-lg": "0px",
        "--radius-xl": "0px",
        "--radius-2xl": "0px",
        "--radius-3xl": "0px",
        "--radius-4xl": "0px",
        "--chart-1": "hsl(250 78% 55%)",
        "--chart-2": "hsl(199 92% 52%)",
        "--chart-3": "hsl(328 84% 60%)",
        "--chart-4": "hsl(44 100% 50%)",
        "--chart-5": "#B8F818",
        "--sidebar": "hsl(73 60% 94%)",
        "--sidebar-foreground": "hsl(229 35% 14%)",
        "--sidebar-primary": "#B8F818",
        "--sidebar-primary-foreground": "hsl(229 35% 10%)",
        "--sidebar-accent": "hsl(216 90% 90%)",
        "--sidebar-accent-foreground": "hsl(229 35% 14%)",
        "--sidebar-border": "hsl(229 35% 28%)",
        "--sidebar-ring": "#B8F818",
        "--variant-error-bg": "hsl(350 100% 95%)",
        "--variant-error-border": "hsl(350 88% 68%)",
        "--variant-error-text": "hsl(350 88% 30%)",
        "--variant-info-bg": "hsl(199 100% 92%)",
        "--variant-info-border": "hsl(199 88% 62%)",
        "--variant-info-text": "hsl(222 70% 24%)",
        "--variant-success-bg": "hsl(85 100% 90%)",
        "--variant-success-border": "hsl(86 85% 54%)",
        "--variant-success-text": "hsl(120 62% 22%)",
        "--variant-warning-bg": "hsl(45 100% 90%)",
        "--variant-warning-border": "hsl(38 96% 55%)",
        "--variant-warning-text": "hsl(25 88% 24%)"
      },
      "html[data-theme=\"corti-showcase-dark\"]": {
        "--font-sans": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "--font-mono": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "--background": "hsl(230 47% 9%)",
        "--foreground": "hsl(84 100% 96%)",
        "--card": "hsl(231 42% 13%)",
        "--card-foreground": "hsl(84 100% 96%)",
        "--popover": "hsl(231 42% 13%)",
        "--popover-foreground": "hsl(84 100% 96%)",
        "--primary": "#B8F818",
        "--primary-foreground": "hsl(230 47% 9%)",
        "--secondary": "hsl(229 40% 24%)",
        "--secondary-foreground": "hsl(84 100% 96%)",
        "--muted": "hsl(229 34% 20%)",
        "--muted-foreground": "hsl(228 24% 72%)",
        "--accent": "#B8F818",
        "--accent-foreground": "hsl(230 47% 9%)",
        "--destructive": "hsl(0 70% 42%)",
        "--destructive-foreground": "hsl(0 0% 100%)",
        "--border": "hsl(229 35% 36%)",
        "--input": "hsl(229 35% 34%)",
        "--ring": "#B8F818",
        "--radius": "0px",
        "--radius-sm": "0px",
        "--radius-md": "0px",
        "--radius-lg": "0px",
        "--radius-xl": "0px",
        "--radius-2xl": "0px",
        "--radius-3xl": "0px",
        "--radius-4xl": "0px",
        "--chart-1": "#B8F818",
        "--chart-2": "hsl(199 92% 60%)",
        "--chart-3": "hsl(328 84% 64%)",
        "--chart-4": "hsl(44 100% 58%)",
        "--chart-5": "hsl(250 82% 68%)",
        "--sidebar": "hsl(231 42% 12%)",
        "--sidebar-foreground": "hsl(84 100% 96%)",
        "--sidebar-primary": "#B8F818",
        "--sidebar-primary-foreground": "hsl(230 47% 9%)",
        "--sidebar-accent": "hsl(229 40% 24%)",
        "--sidebar-accent-foreground": "hsl(84 100% 96%)",
        "--sidebar-border": "hsl(229 35% 36%)",
        "--sidebar-ring": "#B8F818",
        "--variant-error-bg": "hsl(350 70% 14%)",
        "--variant-error-border": "hsl(350 84% 46%)",
        "--variant-error-text": "hsl(350 100% 84%)",
        "--variant-info-bg": "hsl(205 72% 14%)",
        "--variant-info-border": "hsl(199 90% 48%)",
        "--variant-info-text": "hsl(199 100% 80%)",
        "--variant-success-bg": "hsl(102 62% 14%)",
        "--variant-success-border": "#B8F818",
        "--variant-success-text": "hsl(88 100% 82%)",
        "--variant-warning-bg": "hsl(42 82% 16%)",
        "--variant-warning-border": "hsl(45 96% 54%)",
        "--variant-warning-text": "hsl(45 100% 78%)"
      },
      "html[data-theme^=\"corti-showcase\"]": {
        "font-family": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
      },
      "html[data-theme^=\"corti-showcase\"] :is(h1, h2, h3, h4, h5, h6)": {
        "font-family": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "letter-spacing": "0.04em",
        "line-height": "1.35",
        "text-transform": "uppercase"
      }
    }
  },
  "type": "registry:theme"
}